# Copy to web/.env and fill in. Never commit the real .env.
VITE_SOLANA_NETWORK=devnet

# Solana RPC endpoint (e.g. a Helius devnet URL).
VITE_RPC_URL=

# Platform treasury PUBLIC address (not the private key — that lives only in a server secret).
VITE_TREASURY_ADDRESS=

# Supabase project URL + anon (public) key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
